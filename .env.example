# Supabase CLI credentials (for local development and DB management)
# Get your access token from: https://supabase.com/dashboard/account/tokens
# IMPORTANT: This token is for CLI operations only, NOT for deployment
# SUPABASE_ACCESS_TOKEN=sbp_your_token_here
# SUPABASE_PROJECT_REF=nxixwsexfuxpelsthmwd

# Database connection (for production deployment)
# Leave empty to use embedded PGlite in development
# For production, use Supabase connection string (configured as GitHub Secret)
# DATABASE_URL=postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip

# Server configuration
PORT=3100
SERVE_UI=false
BETTER_AUTH_SECRET=paperclip-dev-secret
